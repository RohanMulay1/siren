# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Slack (create app at api.slack.com/apps)
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
SLACK_CHANNEL_ID=C...   # channel to post incident alerts

# GitHub
GITHUB_TOKEN=ghp_...

# AWS (for CloudWatch integration)
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_DEFAULT_REGION=us-east-1

# LangSmith (observability, get at smith.langchain.com)
LANGSMITH_API_KEY=ls__...
LANGSMITH_PROJECT=siren

# App
ENVIRONMENT=development
LOG_LEVEL=INFO

# These are set automatically in docker-compose
# REDIS_URL=redis://localhost:6379
# DATABASE_URL=postgresql+asyncpg://siren:siren@localhost:5432/siren
# QDRANT_URL=http://localhost:6333
